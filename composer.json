{
    "name": "zenretreats/portal",
    "type": "project",
    "description": "Zen Retreats — Client Management Portal (v2 rebuild)",
    "keywords": ["zen-retreats", "real-estate", "portal", "laravel", "inertia"],
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "ext-gd": "*",
        "ext-pdo": "*",
        "barryvdh/laravel-dompdf": "^3.0",
        "guzzlehttp/guzzle": "^7.8",
        "inertiajs/inertia-laravel": "^1.3",
        "laravel/framework": "^11.0",
        "laravel/horizon": "^5.24",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.9",
        "league/csv": "^9.16",
        "predis/predis": "^2.2",
        "spatie/laravel-activitylog": "^4.8",
        "spatie/laravel-backup": "^9.1",
        "spatie/laravel-medialibrary": "^11.5",
        "spatie/laravel-permission": "^6.7",
        "tightenco/ziggy": "^2.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.15",
        "laravel/sail": "^1.29",
        "laravel/telescope": "^5.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "pestphp/pest": "^2.34",
        "pestphp/pest-plugin-laravel": "^2.4",
        "spatie/laravel-ignition": "^2.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "test": "pest",
        "lint": "pint",
        "lint:check": "pint --test"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
