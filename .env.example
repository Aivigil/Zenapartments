APP_NAME="Zen Retreats Portal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Karachi
APP_URL=http://localhost:8000
APP_LOCALE=en

# Branding
APP_PRIMARY_COLOR=1B3A2F
APP_ACCENT_COLOR=5B8C7B

# Logging
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — Postgres (primary)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=zen_retreats_portal
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Session / Cache / Queue — Redis
BROADCAST_CONNECTION=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_DB=1

# Mail (configure per environment)
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@portal.zenretreatspk.com"
MAIL_FROM_NAME="${APP_NAME}"

# SMS gateway (configure per environment)
SMS_PROVIDER=null
SMS_API_URL=
SMS_API_KEY=
SMS_FROM=ZENRETREAT

# WhatsApp (Phase 2)
WHATSAPP_PROVIDER=null
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# GenieCentral CRM integration (configure when API access is available)
GENIECENTRAL_BASE_URL=
GENIECENTRAL_API_KEY=
GENIECENTRAL_WEBHOOK_SECRET=

# Object storage (S3-compatible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_ENDPOINT=

# Currency + locale defaults
DEFAULT_CURRENCY=PKR
ACCEPTED_CURRENCIES=PKR,USD,GBP,EUR,AED
FX_RATE_SOURCE=manual

# Reminders engine
REMINDER_QUIET_HOURS_START=21
REMINDER_QUIET_HOURS_END=09

# Activity log
ACTIVITY_LOGGER_ENABLED=true

# Sanctum / Inertia
SANCTUM_STATEFUL_DOMAINS=localhost:8000,127.0.0.1:8000

# Vite
VITE_APP_NAME="${APP_NAME}"
